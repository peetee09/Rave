# ============================================================
# LPN Investigation System – Environment Variables
# Copy this file to .env for local development.
# On Railway, all variables below are set automatically
# (DATABASE_URL) or via the Railway dashboard.
# ============================================================

# PostgreSQL connection string (provided automatically by Railway)
DATABASE_URL=postgresql://user:password@localhost:5432/lpn_investigations

# Server port (Railway sets PORT automatically)
PORT=3000

# Application environment
NODE_ENV=development
